{
    "name": "framlog.is",
    "version": "1.0.0",
    "description": "Framlagavefurinn",
    "main": "index.js",
    "scripts": {
        "start": "nodemon --exec \"ts-node -r tsconfig-paths/register\" src/server.ts",
        "tw": "npx @tailwindcss/cli -i ./static/css/tw.css -o ./static/css/tw.min.css --watch",
        "dev": "concurrently \"npm:start\" \"npm:tw\"",
        "build": "tsc && copyfiles \"views/**/*\" \"static/**/*\" \"webroot/**/*\" \".build\"",
        "serve": "TS_NODE_BASEURL=./.build node -r tsconfig-paths/register .build/src/server.js",
        "serve-nt": "set TS_NODE_BASEURL=./.build && node -r tsconfig-paths/register .build/src/server.js"
    },
    "keywords": [],
    "author": "Kría Elínarbur <kria.elinarbur@arctictern.is>",
    "license": "UNLICENSED",
    "packageManager": "pnpm@10.10.0",
    "dependencies": {
        "@prisma/adapter-pg": "^7.5.0",
        "@prisma/client": "^7.5.0",
        "@tailwindcss/cli": "^4.1.13",
        "accept-language-parser": "^1.5.0",
        "concurrently": "^9.2.1",
        "cookie-parser": "^1.4.7",
        "dotenv": "^17.3.1",
        "ejs": "^3.1.10",
        "express": "^5.1.0",
        "express-rate-limit": "^8.2.1",
        "pg": "^8.20.0",
        "tailwindcss": "^4.1.13",
        "uglify-js": "^3.19.3",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/accept-language-parser": "^1.5.8",
        "@types/cookie-parser": "^1.4.10",
        "@types/express": "^5.0.3",
        "@types/node": "^24.5.2",
        "@types/pg": "^8.18.0",
        "@types/uglify-js": "^3.17.5",
        "copyfiles": "^2.4.1",
        "nodemon": "^3.1.10",
        "prettier": "^3.6.2",
        "prettier-plugin-ejs": "^1.0.3",
        "prettier-plugin-organize-imports": "^4.3.0",
        "prettier-plugin-tailwindcss": "^0.6.14",
        "prisma": "^7.5.0",
        "ts-node": "^10.9.2",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^5.9.2"
    }
}
